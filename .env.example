# Server
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
SERVER_PUBLIC_URL=http://localhost:4000
TEMP_DIR=
MAX_UPLOAD_MB=250
MAX_JOB_AGE_MS=3600000

# FFmpeg
# Optional. Leave empty to use bundled npm FFmpeg/FFprobe binaries.
FFMPEG_PATH=
FFPROBE_PATH=
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_CRF=30
FFMPEG_PRESET=veryfast
AUDIO_BITRATE=192k

# Google OAuth / YouTube Data API v3
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/youtube/callback
COOKIE_SECURE=false

# Frontend build override. Leave empty for same-origin production builds.
VITE_API_URL=http://localhost:4000
