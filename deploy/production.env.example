# Copy to server/.env on the production server.
# Do not commit real secrets.

NODE_ENV=production
PORT=4000
HOST=127.0.0.1
CLIENT_URL=https://convert.kindeeyudee.com
SERVER_PUBLIC_URL=https://convert.kindeeyudee.com
GOOGLE_REDIRECT_URI=https://convert.kindeeyudee.com/api/youtube/callback
COOKIE_SECURE=true

MAX_UPLOAD_MB=500
TEMP_DIR=/var/tmp/mp3-to-mp4-converter
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_CRF=30
FFMPEG_PRESET=veryfast
AUDIO_BITRATE=192k

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
